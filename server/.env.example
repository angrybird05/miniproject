PORT=8080
JWT_SECRET=change-me
DB_PATH=./data/app.sqlite
UPLOAD_DIR=./uploads
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
SEED_DEMO=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
# If you see TLS/certificate errors with your SMTP (common on local SMTP tools),
# you can temporarily set this to false for development. Keep it true in prod.
SMTP_TLS_REJECT_UNAUTHORIZED=true
# Set true to enable nodemailer debug logs (dev only).
SMTP_DEBUG=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Smart Attendance <no-reply@yourdomain.com>"
